# Server Configuration
PORT=8081
GIN_MODE=release

# Frontend URL
FRONTEND_URL=https://zhix.club

# Database Configuration
DB_HOST=your-db-host.rds.amazonaws.com
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=zhix_payment
DB_PORT=5432

# Redis Configuration
REDIS_HOST=your-redis-host.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# JWT Configuration
JWT_SECRET=your-jwt-secret-key

# Apple Pay Configuration
APPLE_PAY_MERCHANT_ID=merchant.com.zhix.payment
APPLE_PAY_DISPLAY_NAME=ZhiX Club
APPLE_PAY_DOMAIN=zhix.club
APPLE_PAY_CERT_FILE=/path/to/merchant_id.pem
APPLE_PAY_KEY_FILE=/path/to/merchant_id.key
APPLE_ROOT_CA_FILE=/path/to/apple-root-ca.pem

# Payment Gateway (stripe or adyen)
PAYMENT_GATEWAY=stripe

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key

# Adyen Configuration (optional)
ADYEN_API_KEY=your_adyen_api_key
ADYEN_MERCHANT_ACCOUNT=your_merchant_account
