# 数据库配置
DB_HOST=localhost
DB_USER=zhix_user
DB_PASSWORD=your_secure_password
DB_NAME=zhix
DB_PORT=5432
DB_SSLMODE=disable

# Redis配置
REDIS_HOST=localhost:6379
REDIS_PASSWORD=

# JWT配置
JWT_SECRET=your_jwt_secret_key_change_in_production

# 服务器配置
PORT=8080
GIN_MODE=release

# Apple Pay配置
APPLE_PAY_MERCHANT_ID=merchant.club.zhix
APPLE_PAY_DISPLAY_NAME=ZhiX Club
APPLE_PAY_DOMAIN=zhix.club
APPLE_PAY_CERT_FILE=/path/to/merchant_id.pem
APPLE_PAY_KEY_FILE=/path/to/merchant_id.key
APPLE_ROOT_CA_FILE=/path/to/apple_root_ca.pem

# 支付网关配置（选择一个）
PAYMENT_GATEWAY=stripe

# Stripe配置
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Adyen配置（可选）
ADYEN_API_KEY=your_adyen_api_key
ADYEN_MERCHANT_ACCOUNT=your_merchant_account
